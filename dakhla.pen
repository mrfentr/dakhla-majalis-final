              ]
            },
            {
              "type": "text",
              "id": "EWXNo",
              "name": "excerpt",
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "دليل شامل لأنواع الأقمشة التقليدية والحديثة المستخدمة في تنجيد المجالس الصحراوية، مع نصائح للعناية والصيانة. اكتشف كيف تختار القماش الذي يجمع بين الأصالة والجودة.",
              "lineHeight": 1.7,
              "fontFamily": "Cairo",
              "fontSize": 20,
              "fontWeight": "500"
            },
            {
              "type": "frame",
              "id": "PDQ2G",
              "name": "Article Body",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 28,
              "children": [
                {
                  "type": "text",
                  "id": "wzMPb",
                  "name": "h2_1",
                  "fill": "#1A1A1A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "أنواع الأقمشة التقليدية",
                  "lineHeight": 1.3,
                  "fontFamily": "Amiri",
                  "fontSize": 32,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "cUroe",
                  "name": "p1",
                  "fill": "#5A5A5A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "تتميز المجالس الصحراوية بتنوع الأقمشة المستخدمة في صناعتها، حيث تعكس كل قطعة تاريخاً عريقاً من الحرفية والإبداع. من أبرز هذه الأقمشة نجد الصوف الطبيعي الذي يُجمع من الأغنام المحلية، والقطن المغزول يدوياً الذي يُصبغ بألوان طبيعية مستخلصة من النباتات الصحراوية.",
                  "lineHeight": 1.8,
                  "fontFamily": "Cairo",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "uVBrM",
                  "name": "p2",
                  "fill": "#5A5A5A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "يُعد اختيار القماش المناسب أمراً بالغ الأهمية، فهو لا يؤثر فقط على المظهر الجمالي للمجلس، بل يحدد أيضاً مدى راحته ومتانته على المدى الطويل. لذلك ننصح دائماً بالتعرف على خصائص كل نوع قبل اتخاذ القرار.",
                  "lineHeight": 1.8,
                  "fontFamily": "Cairo",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "mLqti",
                  "name": "quoteBlock",
                  "width": "fill_container",
                  "stroke": {
                    "thickness": {
                      "right": 4
                    },
                    "fill": "#B85C38"
                  },
                  "padding": [
                    24,
                    32
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "FudGy",
                      "name": "quoteText",
                      "fill": "#5A5A5A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "\"القماش الجيد هو أساس المجلس المتين. نحن نختار أجود الأقمشة من مصادر محلية لضمان الجودة والأصالة.\"",
                      "lineHeight": 1.7,
                      "fontFamily": "Amiri",
                      "fontSize": 17,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "7kmMP",
                  "name": "h2_2",
                  "fill": "#1A1A1A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "نصائح العناية والصيانة",
                  "lineHeight": 1.3,
                  "fontFamily": "Amiri",
                  "fontSize": 32,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "spRc6",
                  "name": "p3",
                  "fill": "#5A5A5A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "للحفاظ على جمال وجودة قماش المجلس، يُنصح بتنظيفه بانتظام باستخدام المكنسة الكهربائية لإزالة الغبار. في حالة البقع، استخدم قطعة قماش مبللة بالماء الدافئ والصابون الخفيف. تجنب التعرض المباشر لأشعة الشمس لفترات طويلة حتى لا تبهت الألوان.",
                  "lineHeight": 1.8,
                  "fontFamily": "Cairo",
                  "fontSize": 17,
                  "fontWeight": "normal"
                }
              ]
